{
  "name": "mmx-core-ts",
  "version": "1.0.0",
  "private": true,
  "description": "Deterministic Mega Man X gameplay engine with web and desktop clients.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @mmx/web dev",
    "play": "pnpm dev",
    "build": "pnpm --filter @mmx/engine --filter @mmx/renderer-pixi --filter @mmx/web --filter @mmx/sim -r build",
    "build:web": "pnpm --filter @mmx/web build",
    "preview": "pnpm --filter @mmx/web preview",
    "start": "pnpm preview",
    "desktop:dev": "pnpm --filter @mmx/desktop dev",
    "desktop:build": "pnpm --filter @mmx/desktop build",
    "sim": "pnpm --filter @mmx/sim start",
    "replay": "pnpm --filter @mmx/sim replay",
    "level:import": "node tools/import-ldtk.mjs",
    "enemies:import": "node tools/build-enemies.mjs",
    "test": "pnpm --filter @mmx/engine test",
    "lint": "oxlint packages apps tools",
    "lint:fix": "oxlint --fix packages apps tools",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "packageManager": "pnpm@10.28.2"
}

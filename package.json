{
  "name": "mmx.ts",
  "version": "1.0.0",
  "description": "A faithful TypeScript/Node port of the core player gameplay (movement + shooting state machine) from the Mega Man X8 16-bit fan project.",
  "keywords": [
    "mega-man",
    "platformer",
    "state-machine",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "preview": "vite preview",
    "sim": "tsx src/sim/run.ts",
    "replay": "tsx src/sim/replay.ts",
    "level:import": "node tools/import-ldtk.mjs",
    "enemies:import": "node tools/build-enemies.mjs",
    "test": "node --import tsx --test tests/*.test.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "serve": "tsx src/server.ts",
    "play": "pnpm run dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.15.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.12.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
